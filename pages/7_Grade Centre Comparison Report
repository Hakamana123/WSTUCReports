"""
Grade Centre Comparison Report
====================================
Compares two Blackboard Grade Centre snapshots, joined to a collated classlist,
and produces a multi-tab Excel report with:
  1. Overall summary
  2. By Assessment
  3. By Subject + Class
  4. Submission Recovery Leaderboard
  5. Grade Recovery Leaderboard

Usage:
    python gc_comparison_report.py <gc_early.xls> <gc_later.xls> <classlist.xlsx> [output.xlsx]

Inputs:
    gc_early.xls   - Earlier GC export (UTF-16 TSV from Blackboard)
    gc_later.xls   - Later GC export (UTF-16 TSV from Blackboard)
    classlist.xlsx  - Collated classlist with Student ID → Teacher mapping
    output.xlsx     - Optional output filename (default: auto-generated)

The GC filename format is expected to be:
    gc_GEDU00XX_2026_AUT_fullgc_YYYY-MM-DD-HH-MM-SS.xls
"""

import sys, os, re
import pandas as pd
from datetime import datetime
from openpyxl import Workbook
from openpyxl.styles import Font, PatternFill, Alignment, Border, Side
from openpyxl.utils import get_column_letter

# ── Styles ──────────────────────────────────────────────────────────────────
FONT_BODY = Font(name='Arial', size=10)
FONT_HEADER = Font(name='Arial', size=10, bold=True, color='FFFFFF')
FONT_TITLE = Font(name='Arial', size=14, bold=True)
FONT_SUBTITLE = Font(name='Arial', size=11, bold=True, color='333333')
FONT_METRIC = Font(name='Arial', size=20, bold=True)
FONT_METRIC_LABEL = Font(name='Arial', size=9, color='666666')
FONT_DELTA_POS = Font(name='Arial', size=10, bold=True, color='1B7A3D')
FONT_DELTA_NEG = Font(name='Arial', size=10, bold=True, color='C0392B')
FONT_DELTA_ZERO = Font(name='Arial', size=10, color='999999')
FILL_HEADER = PatternFill('solid', fgColor='2C3E50')
FILL_STRIPE = PatternFill('solid', fgColor='F8F9FA')
FILL_CARD = PatternFill('solid', fgColor='EBF5FB')
FILL_GOLD = PatternFill('solid', fgColor='FFF9E6')
FILL_SILVER = PatternFill('solid', fgColor='F2F3F4')
FILL_BRONZE = PatternFill('solid', fgColor='FDF2E9')
FILL_GREEN_LIGHT = PatternFill('solid', fgColor='E8F8F0')
FILL_RED_LIGHT = PatternFill('solid', fgColor='FDEDEC')
THIN_BORDER = Border(
    bottom=Side(style='thin', color='DEE2E6')
)
PCT_FMT = '0.0%'


def parse_gc(filepath):
    """Parse a Blackboard Grade Centre export (UTF-16 TSV disguised as .xls)."""
    try:
        df = pd.read_csv(filepath, encoding='utf-16-le', sep='\t', quotechar='"')
    except Exception:
        df = pd.read_csv(filepath, encoding='utf-16', sep='\t', quotechar='"')
    df['Username'] = df['Username'].astype(str).str.strip()
    return df


def extract_date(filename):
    """Extract date from GC filename like gc_GEDU0017_..._2026-05-18-18-13-27.xls"""
    m = re.search(r'(\d{4}-\d{2}-\d{2})-\d{2}-\d{2}-\d{2}', os.path.basename(filename))
    if m:
        return datetime.strptime(m.group(1), '%Y-%m-%d')
    return None


def extract_subject(filename):
    """Extract subject code from GC filename like gc_GEDU0017_..."""
    m = re.search(r'(GEDU\d+)', os.path.basename(filename), re.IGNORECASE)
    return m.group(1).upper() if m else 'UNKNOWN'


def get_assessment_cols(df):
    """Find main assessment columns (exclude resubmission links)."""
    return [c for c in df.columns
            if c.lower().startswith('assessment')
            and 'resubmission' not in c.lower()]


def get_activity_cols(df):
    """Find activity/participation columns."""
    return [c for c in df.columns if 'complete/incomplete' in c.lower()]


def short_name(col):
    """Shorten column name: 'Assessment 1: Participation [Total Pts...]' → 'Assessment 1: Participation'"""
    return col.split('[')[0].strip()


def categorize(val):
    """Categorize a GC cell value."""
    if pd.isna(val) or str(val).strip() == '':
        return 'No Submission'
    s = str(val).strip()
    if s == 'Needs Grading':
        return 'Needs Grading'
    if s == 'Satisfactory':
        return 'Satisfactory'
    if s == 'Unsatisfactory':
        return 'Unsatisfactory'
    if s == 'Complete':
        return 'Complete'
    try:
        float(s)
        return 'Scored'
    except ValueError:
        return s


def build_comparison(gc_early, gc_later, classlist):
    """Build the full comparison dataset."""
    cl = classlist.copy()
    cl['Student ID'] = cl['Student ID'].astype(str).str.strip()

    join_cols = ['Student ID', 'Discipline Subject', 'Discipline Class', 'Discipline Teacher']
    available_cols = [c for c in join_cols if c in cl.columns]

    m_early = gc_early.merge(cl[available_cols], left_on='Username', right_on='Student ID', how='left')
    m_later = gc_later.merge(cl[available_cols], left_on='Username', right_on='Student ID', how='left')

    # Filter to available students
    m_early = m_early[m_early['Availability'] == 'Yes'].copy()
    m_later = m_later[m_later['Availability'] == 'Yes'].copy()

    m_early['Discipline Teacher'] = m_early['Discipline Teacher'].fillna('(no match)')
    m_later['Discipline Teacher'] = m_later['Discipline Teacher'].fillna('(no match)')
    m_early['Discipline Subject'] = m_early['Discipline Subject'].fillna('(no match)')
    m_later['Discipline Subject'] = m_later['Discipline Subject'].fillna('(no match)')
    m_early['Discipline Class'] = m_early['Discipline Class'].fillna('')
    m_later['Discipline Class'] = m_later['Discipline Class'].fillna('')

    return m_early, m_later


def aggregate_by_teacher(m_early, m_later, assessment_cols):
    """Aggregate assessment data by teacher for each assessment."""
    results = {}
    common_uids = set(m_early['Username']) & set(m_later['Username'])
    e = m_early[m_early['Username'].isin(common_uids)].set_index('Username')
    l = m_later[m_later['Username'].isin(common_uids)].set_index('Username')

    for col in assessment_cols:
        if col not in e.columns or col not in l.columns:
            continue
        teacher_data = []
        teachers = sorted(l['Discipline Teacher'].unique())
        for t in teachers:
            uids = l[l['Discipline Teacher'] == t].index
            n = len(uids)
            if n == 0:
                continue
            v1 = e.loc[e.index.isin(uids), col].reindex(uids).apply(categorize)
            v2 = l.loc[l.index.isin(uids), col].reindex(uids).apply(categorize)

            row = {
                'Teacher': t,
                'Students': n,
                'Sat_early': (v1 == 'Satisfactory').sum(),
                'Sat_later': (v2 == 'Satisfactory').sum(),
                'Unsat_early': (v1 == 'Unsatisfactory').sum(),
                'Unsat_later': (v2 == 'Unsatisfactory').sum(),
                'NG_early': (v1 == 'Needs Grading').sum(),
                'NG_later': (v2 == 'Needs Grading').sum(),
                'NS_early': (v1 == 'No Submission').sum(),
                'NS_later': (v2 == 'No Submission').sum(),
            }
            # Transitions
            sub_recovered = ((v1 == 'No Submission') & (v2 != 'No Submission')).sum()
            grade_recovered = ((v1 == 'Unsatisfactory') & (v2 == 'Satisfactory')).sum()
            ng_cleared = ((v1 == 'Needs Grading') & (v2 == 'Satisfactory')).sum()
            row['Sub_recovered'] = sub_recovered
            row['Grade_recovered'] = grade_recovered
            row['NG_cleared'] = ng_cleared
            row['Pool_NS'] = row['NS_early']  # how many were missing to begin with
            row['Pool_Unsat'] = row['Unsat_early']  # how many were unsat to begin with
            teacher_data.append(row)
        results[short_name(col)] = teacher_data
    return results


def aggregate_by_class(m_early, m_later, assessment_cols):
    """Aggregate by Discipline Subject + Class + Teacher."""
    results = {}
    common_uids = set(m_early['Username']) & set(m_later['Username'])
    e = m_early[m_early['Username'].isin(common_uids)].copy()
    l = m_later[m_later['Username'].isin(common_uids)].copy()
    e['Group'] = e['Discipline Subject'] + ' — ' + e['Discipline Class'] + ' | ' + e['Discipline Teacher']
    l['Group'] = l['Discipline Subject'] + ' — ' + l['Discipline Class'] + ' | ' + l['Discipline Teacher']
    e = e.set_index('Username')
    l = l.set_index('Username')

    for col in assessment_cols:
        if col not in e.columns or col not in l.columns:
            continue
        rows = []
        for grp in sorted(l['Group'].unique()):
            uids = l[l['Group'] == grp].index
            n = len(uids)
            if n == 0:
                continue
            v1 = e.loc[e.index.isin(uids), col].reindex(uids).apply(categorize)
            v2 = l.loc[l.index.isin(uids), col].reindex(uids).apply(categorize)
            parts = grp.split(' | ')
            teacher = parts[1] if len(parts) > 1 else ''
            subj_cls = parts[0] if parts else grp
            rows.append({
                'Subject_Class': subj_cls,
                'Teacher': teacher,
                'Students': n,
                'Sat_early': (v1 == 'Satisfactory').sum(),
                'Sat_later': (v2 == 'Satisfactory').sum(),
                'Unsat_early': (v1 == 'Unsatisfactory').sum(),
                'Unsat_later': (v2 == 'Unsatisfactory').sum(),
                'NG_early': (v1 == 'Needs Grading').sum(),
                'NG_later': (v2 == 'Needs Grading').sum(),
                'NS_early': (v1 == 'No Submission').sum(),
                'NS_later': (v2 == 'No Submission').sum(),
                'Sub_recovered': ((v1 == 'No Submission') & (v2 != 'No Submission')).sum(),
                'Grade_recovered': ((v1 == 'Unsatisfactory') & (v2 == 'Satisfactory')).sum(),
            })
        results[short_name(col)] = rows
    return results


# ── Excel Writing Helpers ───────────────────────────────────────────────────

def write_header_row(ws, row, headers, col_start=1):
    for i, h in enumerate(headers):
        cell = ws.cell(row=row, column=col_start + i, value=h)
        cell.font = FONT_HEADER
        cell.fill = FILL_HEADER
        cell.alignment = Alignment(horizontal='center', vertical='center', wrap_text=True)


def write_data_row(ws, row, values, col_start=1, stripe=False):
    for i, v in enumerate(values):
        cell = ws.cell(row=row, column=col_start + i, value=v)
        cell.font = FONT_BODY
        cell.border = THIN_BORDER
        if stripe:
            cell.fill = FILL_STRIPE
        cell.alignment = Alignment(horizontal='center', vertical='center')
    # Left-align first column (teacher/label)
    ws.cell(row=row, column=col_start).alignment = Alignment(horizontal='left', vertical='center')


def write_delta_cell(ws, row, col, val):
    cell = ws.cell(row=row, column=col, value=val)
    if val > 0:
        cell.font = FONT_DELTA_POS
        cell.value = f'+{val}'
    elif val < 0:
        cell.font = FONT_DELTA_NEG
    else:
        cell.font = FONT_DELTA_ZERO
        cell.value = '—'
    cell.alignment = Alignment(horizontal='center')


def write_metric_card(ws, row, col, label, value, width=2):
    cell = ws.cell(row=row, column=col, value=label)
    cell.font = FONT_METRIC_LABEL
    cell = ws.cell(row=row + 1, column=col, value=value)
    cell.font = FONT_METRIC
    for c in range(col, col + width):
        ws.cell(row=row, column=c).fill = FILL_CARD
        ws.cell(row=row + 1, column=c).fill = FILL_CARD


def auto_width(ws, min_w=10, max_w=30):
    for col_cells in ws.columns:
        lengths = []
        for cell in col_cells:
            if cell.value:
                lengths.append(len(str(cell.value)))
        if lengths:
            w = min(max(max(lengths) + 2, min_w), max_w)
            ws.column_dimensions[get_column_letter(col_cells[0].column)].width = w


# ── Sheet Writers ───────────────────────────────────────────────────────────

def write_overall(wb, subject, date_early, date_later, total_avail, by_teacher, by_class):
    ws = wb.create_sheet('Overall')
    ws.sheet_properties.tabColor = '2C3E50'
    r = 1
    ws.cell(row=r, column=1, value=f'{subject} — Grade Centre Comparison Report').font = FONT_TITLE
    r += 1
    ws.cell(row=r, column=1, value=f'{date_early} → {date_later}  ·  {total_avail} available students').font = FONT_METRIC_LABEL
    r += 2

    for aname, tdata in by_teacher.items():
        ws.cell(row=r, column=1, value=aname).font = FONT_SUBTITLE
        r += 1
        total_n = sum(t['Students'] for t in tdata)
        sat_e = sum(t['Sat_early'] for t in tdata)
        sat_l = sum(t['Sat_later'] for t in tdata)
        ns_e = sum(t['NS_early'] for t in tdata)
        ns_l = sum(t['NS_later'] for t in tdata)
        ng_e = sum(t['NG_early'] for t in tdata)
        ng_l = sum(t['NG_later'] for t in tdata)
        unsat_e = sum(t['Unsat_early'] for t in tdata)
        unsat_l = sum(t['Unsat_later'] for t in tdata)
        sub_rec = sum(t['Sub_recovered'] for t in tdata)
        grd_rec = sum(t['Grade_recovered'] for t in tdata)

        labels = ['Satisfactory', 'Unsatisfactory', 'Needs Grading', 'No Submission', 'Subs Recovered', 'Grades Recovered']
        early_vals = [sat_e, unsat_e, ng_e, ns_e, '', '']
        later_vals = [sat_l, unsat_l, ng_l, ns_l, sub_rec, grd_rec]

        write_header_row(ws, r, ['Status', 'Early', 'Later', 'Δ'])
        r += 1
        for i, lbl in enumerate(labels):
            ev = early_vals[i]
            lv = later_vals[i]
            delta = (lv - ev) if isinstance(ev, int) and isinstance(lv, int) else ''
            write_data_row(ws, r, [lbl, ev, lv, ''], stripe=(i % 2 == 0))
            if isinstance(delta, int):
                write_delta_cell(ws, r, 4, delta)
            r += 1

        sub_rate_e = (total_n - ns_e) / total_n if total_n > 0 else 0
        sub_rate_l = (total_n - ns_l) / total_n if total_n > 0 else 0
        sat_rate_e = sat_e / total_n if total_n > 0 else 0
        sat_rate_l = sat_l / total_n if total_n > 0 else 0
        ws.cell(row=r, column=1, value='Submission Rate').font = Font(name='Arial', size=10, bold=True)
        c2 = ws.cell(row=r, column=2, value=sub_rate_e); c2.number_format = PCT_FMT; c2.font = FONT_BODY
        c3 = ws.cell(row=r, column=3, value=sub_rate_l); c3.number_format = PCT_FMT; c3.font = FONT_BODY
        r += 1
        ws.cell(row=r, column=1, value='Satisfactory Rate').font = Font(name='Arial', size=10, bold=True)
        c2 = ws.cell(row=r, column=2, value=sat_rate_e); c2.number_format = PCT_FMT; c2.font = FONT_BODY
        c3 = ws.cell(row=r, column=3, value=sat_rate_l); c3.number_format = PCT_FMT; c3.font = FONT_BODY
        r += 2

    auto_width(ws)


def write_by_assessment(wb, by_teacher, date_early, date_later):
    ws = wb.create_sheet('By Assessment')
    ws.sheet_properties.tabColor = '2980B9'
    r = 1

    for aname, tdata in by_teacher.items():
        ws.cell(row=r, column=1, value=aname).font = FONT_SUBTITLE
        r += 1
        headers = ['Teacher', 'N', f'Sat ({date_early})', f'Sat ({date_later})', 'Sat Δ',
                    f'Unsat ({date_early})', f'Unsat ({date_later})', 'Unsat Δ',
                    f'NdGrd ({date_early})', f'NdGrd ({date_later})',
                    f'NoSub ({date_early})', f'NoSub ({date_later})', 'NoSub Δ',
                    'Sub Rec', 'Grd Rec']
        write_header_row(ws, r, headers)
        r += 1

        sorted_data = sorted(tdata, key=lambda x: x['Students'], reverse=True)
        for i, t in enumerate(sorted_data):
            if t['Teacher'] == '(no match)':
                continue
            vals = [
                t['Teacher'], t['Students'],
                t['Sat_early'], t['Sat_later'], '',
                t['Unsat_early'], t['Unsat_later'], '',
                t['NG_early'], t['NG_later'],
                t['NS_early'], t['NS_later'], '',
                t['Sub_recovered'], t['Grade_recovered']
            ]
            write_data_row(ws, r, vals, stripe=(i % 2 == 0))
            write_delta_cell(ws, r, 5, t['Sat_later'] - t['Sat_early'])
            write_delta_cell(ws, r, 8, t['Unsat_later'] - t['Unsat_early'])
            write_delta_cell(ws, r, 13, t['NS_later'] - t['NS_early'])
            r += 1

        # Totals row
        tot = {k: sum(t[k] for t in tdata if t['Teacher'] != '(no match)') for k in
               ['Students', 'Sat_early', 'Sat_later', 'Unsat_early', 'Unsat_later',
                'NG_early', 'NG_later', 'NS_early', 'NS_later', 'Sub_recovered', 'Grade_recovered']}
        vals = ['TOTAL', tot['Students'], tot['Sat_early'], tot['Sat_later'], '',
                tot['Unsat_early'], tot['Unsat_later'], '', tot['NG_early'], tot['NG_later'],
                tot['NS_early'], tot['NS_later'], '', tot['Sub_recovered'], tot['Grade_recovered']]
        write_data_row(ws, r, vals)
        for c in range(1, len(vals) + 1):
            ws.cell(row=r, column=c).font = Font(name='Arial', size=10, bold=True)
        write_delta_cell(ws, r, 5, tot['Sat_later'] - tot['Sat_early'])
        write_delta_cell(ws, r, 8, tot['Unsat_later'] - tot['Unsat_early'])
        write_delta_cell(ws, r, 13, tot['NS_later'] - tot['NS_early'])
        r += 2

    auto_width(ws)


def write_by_class(wb, by_class, date_early, date_later):
    ws = wb.create_sheet('By Subject + Class')
    ws.sheet_properties.tabColor = '27AE60'
    r = 1

    for aname, rows in by_class.items():
        ws.cell(row=r, column=1, value=aname).font = FONT_SUBTITLE
        r += 1
        headers = ['Subject — Class', 'Teacher', 'N',
                    f'Sat', f'Sat→', 'Sat Δ',
                    f'Unsat', f'Unsat→', 'Unsat Δ',
                    'NoSub', 'NoSub→', 'NoSub Δ',
                    'Sub Rec', 'Grd Rec']
        write_header_row(ws, r, headers)
        r += 1

        sorted_rows = sorted(rows, key=lambda x: x['Students'], reverse=True)
        for i, row in enumerate(sorted_rows):
            if row['Teacher'] == '(no match)':
                continue
            vals = [
                row['Subject_Class'], row['Teacher'], row['Students'],
                row['Sat_early'], row['Sat_later'], '',
                row['Unsat_early'], row['Unsat_later'], '',
                row['NS_early'], row['NS_later'], '',
                row['Sub_recovered'], row['Grade_recovered']
            ]
            write_data_row(ws, r, vals, stripe=(i % 2 == 0))
            write_delta_cell(ws, r, 6, row['Sat_later'] - row['Sat_early'])
            write_delta_cell(ws, r, 9, row['Unsat_later'] - row['Unsat_early'])
            write_delta_cell(ws, r, 12, row['NS_later'] - row['NS_early'])
            r += 1
        r += 1

    auto_width(ws)


def write_leaderboard(wb, by_teacher, board_type='submission'):
    """Write a leaderboard sheet. board_type: 'submission' or 'grade'."""
    if board_type == 'submission':
        title = 'Submission Recovery'
        tab_color = 'E67E22'
        metric_key = 'Sub_recovered'
        pool_key = 'Pool_NS'
        metric_label = 'Submissions Recovered'
        pool_label = 'Missing Pool'
    else:
        title = 'Grade Recovery'
        tab_color = '8E44AD'
        metric_key = 'Grade_recovered'
        pool_key = 'Pool_Unsat'
        metric_label = 'Grades Recovered'
        pool_label = 'Unsatisfactory Pool'

    ws = wb.create_sheet(title)
    ws.sheet_properties.tabColor = tab_color
    r = 1
    ws.cell(row=r, column=1, value=f'{title} Leaderboard').font = FONT_TITLE
    r += 2

    # Aggregate across all assessments per teacher
    teacher_totals = {}
    for aname, tdata in by_teacher.items():
        for t in tdata:
            if t['Teacher'] == '(no match)':
                continue
            name = t['Teacher']
            if name not in teacher_totals:
                teacher_totals[name] = {
                    'Students': t['Students'],
                    'recovered': 0,
                    'pool': 0,
                    'details': {}
                }
            teacher_totals[name]['recovered'] += t[metric_key]
            teacher_totals[name]['pool'] += t[pool_key]
            teacher_totals[name]['details'][aname] = {
                'recovered': t[metric_key],
                'pool': t[pool_key]
            }

    # Sort by recovery rate (recovered/pool), then raw count
    ranked = []
    for name, d in teacher_totals.items():
        rate = d['recovered'] / d['pool'] if d['pool'] > 0 else 0
        ranked.append({
            'Teacher': name,
            'Students': d['Students'],
            'Recovered': d['recovered'],
            'Pool': d['pool'],
            'Rate': rate,
            'details': d['details']
        })

    ranked.sort(key=lambda x: (-x['Rate'], -x['Recovered']))

    # Only show teachers who had something to recover
    ranked_with_pool = [r for r in ranked if r['Pool'] > 0]
    ranked_no_pool = [r for r in ranked if r['Pool'] == 0]

    assessment_names = list(by_teacher.keys())
    headers = ['Rank', 'Teacher', 'Students', metric_label, pool_label, 'Recovery %']
    for an in assessment_names:
        headers.append(f'{an}')
    write_header_row(ws, r, headers)
    r += 1

    podium_fills = [FILL_GOLD, FILL_SILVER, FILL_BRONZE]
    for i, t in enumerate(ranked_with_pool):
        rank = i + 1
        vals = [rank, t['Teacher'], t['Students'], t['Recovered'], t['Pool'], t['Rate']]
        for an in assessment_names:
            d = t['details'].get(an, {})
            rec = d.get('recovered', 0)
            pool = d.get('pool', 0)
            vals.append(f'{rec}/{pool}' if pool > 0 else '—')
        write_data_row(ws, r, vals, stripe=(i % 2 == 0))
        ws.cell(row=r, column=6).number_format = PCT_FMT
        # Highlight recovery count green if > 0
        if t['Recovered'] > 0:
            ws.cell(row=r, column=4).font = FONT_DELTA_POS

        # Podium highlighting
        if rank <= 3 and t['Recovered'] > 0:
            fill = podium_fills[rank - 1]
            for c in range(1, len(vals) + 1):
                ws.cell(row=r, column=c).fill = fill
        r += 1

    # Separator for teachers with nothing to recover
    if ranked_no_pool:
        r += 1
        ws.cell(row=r, column=1, value='Teachers with no outstanding items to recover:').font = FONT_METRIC_LABEL
        r += 1
        for t in sorted(ranked_no_pool, key=lambda x: x['Teacher']):
            ws.cell(row=r, column=2, value=t['Teacher']).font = FONT_BODY
            ws.cell(row=r, column=3, value=t['Students']).font = FONT_BODY
            r += 1

    auto_width(ws)


# ── Main ────────────────────────────────────────────────────────────────────

def main():
    if len(sys.argv) < 4:
        print(__doc__)
        sys.exit(1)

    gc_file_1 = sys.argv[1]
    gc_file_2 = sys.argv[2]
    classlist_file = sys.argv[3]
    output_file = sys.argv[4] if len(sys.argv) > 4 else None

    # Determine which is earlier
    d1 = extract_date(gc_file_1)
    d2 = extract_date(gc_file_2)
    if d1 and d2 and d1 > d2:
        gc_file_1, gc_file_2 = gc_file_2, gc_file_1
        d1, d2 = d2, d1

    date_early = d1.strftime('%d %b') if d1 else 'Early'
    date_later = d2.strftime('%d %b') if d2 else 'Later'
    subject = extract_subject(gc_file_1)

    if not output_file:
        output_file = f'{subject}_GC_Comparison_{date_early.replace(" ", "")}_{date_later.replace(" ", "")}.xlsx'

    print(f'Subject:    {subject}')
    print(f'Early GC:   {os.path.basename(gc_file_1)} ({date_early})')
    print(f'Later GC:   {os.path.basename(gc_file_2)} ({date_later})')
    print(f'Classlist:  {os.path.basename(classlist_file)}')
    print(f'Output:     {output_file}')
    print()

    # Parse inputs
    print('Parsing GC exports...')
    gc_early = parse_gc(gc_file_1)
    gc_later = parse_gc(gc_file_2)

    print('Reading classlist...')
    cl = pd.read_excel(classlist_file, sheet_name=0)

    # Build comparison
    print('Joining and comparing...')
    m_early, m_later = build_comparison(gc_early, gc_later, cl)
    total_avail = len(m_later)
    matched = (m_later['Discipline Teacher'] != '(no match)').sum()
    print(f'  Available students: {total_avail}')
    print(f'  Matched to teacher: {matched}')

    assessment_cols = get_assessment_cols(gc_later)
    print(f'  Assessment columns: {len(assessment_cols)}')
    for c in assessment_cols:
        print(f'    - {short_name(c)}')

    # Aggregate
    print('Aggregating by teacher...')
    by_teacher = aggregate_by_teacher(m_early, m_later, assessment_cols)

    print('Aggregating by class...')
    by_class = aggregate_by_class(m_early, m_later, assessment_cols)

    # Build workbook
    print('Writing report...')
    wb = Workbook()
    wb.remove(wb.active)

    write_overall(wb, subject, date_early, date_later, total_avail, by_teacher, by_class)
    write_by_assessment(wb, by_teacher, date_early, date_later)
    write_by_class(wb, by_class, date_early, date_later)
    write_leaderboard(wb, by_teacher, board_type='submission')
    write_leaderboard(wb, by_teacher, board_type='grade')

    wb.save(output_file)
    print(f'\nDone → {output_file}')


